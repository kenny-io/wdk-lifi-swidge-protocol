# LI.FI WDK Swidge Protocol — integration test environment configuration
# Copy this file to .env and fill in your values. Never commit .env to version control.

# JSON-RPC URL for the source chain used in integration tests
INTEGRATION_RPC_URL=https://mainnet.infura.io/v3/YOUR_INFURA_PROJECT_ID

# BIP-39 seed phrase for the funded wallet used in Tier 3 execution tests (12 or 24 words)
INTEGRATION_SEED_PHRASE=your twelve word seed phrase goes here and is never shared

# A known completed transaction hash on the source chain for status polling tests
INTEGRATION_KNOWN_TX_HASH=0x
